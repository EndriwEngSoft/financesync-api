# ============================================
# KUBERNETES SECRET
# ============================================
# Secret armazena dados SENSÍVEIS:
# - Senhas
# - Tokens (JWT)
# - API Keys
#
# Em produção: usar Vault, AWS Secrets Manager
# Aqui é apenas exemplo para desenvolvimento
# ============================================

apiVersion: v1
kind: Secret
metadata:
  name: financesync-secret
  namespace: financesync
  labels:
    app: financesync
type: Opaque
stringData:
  # ===== DATABASE PASSWORD =====
  DB_PASSWORD: "123456"
  POSTGRES_PASSWORD: "123456"

  # ===== JWT SECURITY =====
  JWT_SECRET: "Rm6CTAuNDBC8JxuxdsKRFKZMsy4DVyPNAXKHvxowqtx1ZB4ruEbROsvtir5U8JLC"
  JWT_EXPIRATION: "86400000"
