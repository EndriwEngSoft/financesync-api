# ============================================
# KUBERNETES SECRET - TEMPLATE
# ============================================
# Secret stores sensitive data:
# - Passwords
# - Tokens (JWT)
# - API Keys
#
# IMPORTANT: Do NOT commit secret.yaml to git!
# Copy this file to secret.yaml and fill in values
# In production: use Vault, AWS Secrets Manager, Azure Key Vault
# ============================================

apiVersion: v1
kind: Secret
metadata:
  name: financesync-secret
  namespace: financesync
  labels:
    app: financesync
type: Opaque
stringData:
  # ===== DATABASE PASSWORD =====
  DB_PASSWORD: "REPLACE_WITH_DATABASE_PASSWORD"
  POSTGRES_PASSWORD: "REPLACE_WITH_DATABASE_PASSWORD"

  # ===== JWT SECURITY =====
  JWT_SECRET: "REPLACE_WITH_STRONG_JWT_SECRET_KEY"
  JWT_EXPIRATION: "86400000"
