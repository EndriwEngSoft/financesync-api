# ===== DATABASE =====
# Nota: DB_HOST é definido pelo docker-compose.yml como 'postgres' (nome do serviço)
# Não defina DB_HOST aqui - ele será sobrescrito
DB_PORT=5432
DB_NAME=financesync_db
DB_USER=postgres
DB_PASSWORD=seu_password_seguro_aqui
POSTGRES_PASSWORD=seu_password_seguro_aqui

# ===== SECURITY =====
JWT_SECRET=sua_chave_jwt_super_segura_minimo_256_caracteres_aqui_mudarpara_producao
JWT_EXPIRATION=86400000

# ===== SERVER =====
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api